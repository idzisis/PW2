<Window x:Class="PotatoWarehouse.EditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rediģēt ierakstu"
        Width="400" Height="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Rediģēt ierakstu" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="Datums" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
            <DatePicker x:Name="EditDatePicker"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="Šķirne" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
            <ComboBox x:Name="EditVarietyCombo" Style="{StaticResource ModernComboBox}" DisplayMemberPath="Name" SelectedValuePath="Id"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,12">
            <TextBlock Text="Kalibrs" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
            <ComboBox x:Name="EditCaliberCombo" Style="{StaticResource ModernComboBox}" DisplayMemberPath="Name" SelectedValuePath="Id"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Margin="0,0,0,12">
            <TextBlock Text="Sv. (t)" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
            <TextBox x:Name="EditWeight" Style="{StaticResource ModernTextBox}"/>
        </StackPanel>

        <StackPanel Grid.Row="5" Margin="0,0,0,12" x:Name="CountPanel">
            <TextBlock Text="Daudz" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
            <TextBox x:Name="EditCount" Style="{StaticResource ModernTextBox}"/>
        </StackPanel>

        <StackPanel Grid.Row="5" Margin="0,0,0,12" x:Name="BuyerPanel" Visibility="Collapsed">
            <TextBlock Text="Pircējs" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
            <TextBox x:Name="EditBuyer" Style="{StaticResource ModernTextBox}"/>
        </StackPanel>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Atcelt" Style="{StaticResource ModernButton}" Click="CancelClick" Margin="0,0,8,0" Width="80"/>
            <Button Content="Saglabāt" Style="{StaticResource AccentButton}" Click="SaveClick" Width="100"/>
        </StackPanel>
    </Grid>
</Window>
