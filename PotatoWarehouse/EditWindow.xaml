<Window x:Class="PotatoWarehouse.EditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rediģēt ierakstu"
        Width="450" Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource AccentBrush}" CornerRadius="12" Padding="20,16" Margin="0,0,0,24">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="✏️" FontSize="24" Margin="0,0,12,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="HeaderText" Text="Rediģēt ierakstu" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Date -->
        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <TextBlock Text="DATUMS" Margin="0,0,0,8" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold"/>
            <DatePicker x:Name="EditDatePicker" Padding="12,10" FontSize="14"/>
        </StackPanel>

        <!-- Variety & Caliber Row -->
        <Grid Grid.Row="2" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0">
                <TextBlock Text="ŠĶIRNE" Margin="0,0,0,8" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold"/>
                <ComboBox x:Name="EditVarietyCombo" Style="{StaticResource ModernComboBox}" DisplayMemberPath="Name" SelectedValuePath="Id" Padding="12,10"/>
            </StackPanel>
            
            <StackPanel Grid.Column="2">
                <TextBlock Text="KALIBRS" Margin="0,0,0,8" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold"/>
                <ComboBox x:Name="EditCaliberCombo" Style="{StaticResource ModernComboBox}" DisplayMemberPath="Name" SelectedValuePath="Id" Padding="12,10"/>
            </StackPanel>
        </Grid>

        <!-- Weight -->
        <StackPanel Grid.Row="3" Margin="0,0,0,16">
            <TextBlock Text="SVARS (tonnās)" Margin="0,0,0,8" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold"/>
            <TextBox x:Name="EditWeight" Style="{StaticResource ModernTextBox}" Padding="12,10" FontSize="14"/>
        </StackPanel>

        <!-- Count (for Incoming) -->
        <StackPanel Grid.Row="4" Margin="0,0,0,16" x:Name="CountPanel">
            <TextBlock Text="DAUDZUMS (konteineri)" Margin="0,0,0,8" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold"/>
            <TextBox x:Name="EditCount" Style="{StaticResource ModernTextBox}" Padding="12,10" FontSize="14"/>
        </StackPanel>

        <!-- Buyer (for Outgoing) -->
        <StackPanel Grid.Row="4" Margin="0,0,0,16" x:Name="BuyerPanel" Visibility="Collapsed">
            <TextBlock Text="PIRCĒJS" Margin="0,0,0,8" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold"/>
            <TextBox x:Name="EditBuyer" Style="{StaticResource ModernTextBox}" Padding="12,10" FontSize="14"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
            <Button Content="Atcelt" Style="{StaticResource ModernButton}" Click="CancelClick" Padding="20,12" Margin="0,0,12,0"/>
            <Button Content="💾 Saglabāt" Style="{StaticResource AccentButton}" Click="SaveClick" Padding="20,12"/>
        </StackPanel>
    </Grid>
</Window>
