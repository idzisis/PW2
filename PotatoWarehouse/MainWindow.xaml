<Window x:Class="PotatoWarehouse.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Noliktava"
        Width="1280" Height="800"
        MinWidth="1000" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Modern Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <DockPanel>
                <!-- Logo & Season -->
                <StackPanel DockPanel.Dock="Top" Margin="20,28,20,24">
                    <!-- Logo -->
                    <StackPanel Orientation="Horizontal" Margin="8,0,0,20">
                        <Border Background="#FFA033" CornerRadius="12" Padding="10">
                            <TextBlock Text="🥔" FontSize="22"/>
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Noliktava" FontSize="20" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="Warehouse System" FontSize="11" Foreground="#6B8F9C"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <!-- Season Selector -->
                    <Border Background="#1A5D4A" CornerRadius="14" Padding="16,12" Margin="0,4,0,0">
                        <StackPanel>
                            <TextBlock Text="PAŠĒJĀ SEZONA" FontSize="10" FontWeight="SemiBold" Foreground="#6B8F9C" Margin="0,0,0,6"/>
                            <TextBlock x:Name="SeasonLabel" Text="Izvēlaties sezonu" FontSize="15" FontWeight="SemiBold" Foreground="White"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Navigation -->
                <StackPanel Margin="12,0,12,16">
                    <Button Style="{StaticResource NavButton}" Click="NavigateHome" x:Name="HomeNav" Margin="0,0,0,4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏠" FontSize="16" Margin="0,0,14,0"/>
                            <TextBlock Text="Dashboard" VerticalAlignment="Center" FontSize="14"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}" Click="NavigateIncoming" x:Name="IncomingNav" Margin="0,0,0,4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📥" FontSize="16" Margin="0,0,14,0"/>
                            <TextBlock Text="Ienākošie" VerticalAlignment="Center" FontSize="14"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}" Click="NavigateOutgoing" x:Name="OutgoingNav" Margin="0,0,0,4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📤" FontSize="16" Margin="0,0,14,0"/>
                            <TextBlock Text="Izejošie" VerticalAlignment="Center" FontSize="14"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}" Click="NavigateSettings" x:Name="SettingsNav">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙️" FontSize="16" Margin="0,0,14,0"/>
                            <TextBlock Text="Iestatījumi" VerticalAlignment="Center" FontSize="14"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Footer -->
                <TextBlock DockPanel.Dock="Bottom" Text="v2.0 • Modern UI" Foreground="#4A7C6F" FontSize="11" Margin="20,0,20,16" HorizontalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Content Area -->
        <Border Grid.Column="1" Background="{StaticResource BackgroundBrush}">
            <Grid x:Name="ContentArea" Margin="28">
                <!-- Home Page -->
                <Grid x:Name="HomePage">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Page Header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,28">
                        <TextBlock Text="Dashboard" FontSize="32" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Pārskats par noliktavas darbību" FontSize="15" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0"/>
                    </StackPanel>

                    <!-- Stats Cards Row - Modern Design -->
                    <Grid Grid.Row="1" Margin="0,0,0,28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Card 1: Total Inventory - Green -->
                        <Border Grid.Column="0" CornerRadius="24" Padding="24" Background="#00875A">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="30" ShadowDepth="10" Opacity="0.25" Color="#00875A"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                                    <Border Background="#FFFFFF" CornerRadius="14" Padding="12">
                                        <TextBlock Text="📦" FontSize="22"/>
                                    </Border>
                                    <TextBlock Text="Kopējais atlikums" Foreground="#A5D6C0" FontSize="15" Margin="14,0,0,0" VerticalAlignment="Center" FontWeight="Medium"/>
                                </StackPanel>
                                <TextBlock Grid.Row="1" x:Name="TotalWeightText" Text="0 t" FontSize="42" FontWeight="Bold" Foreground="White" Margin="0,8,0,8"/>
                                <TextBlock Grid.Row="2" Text="noliktavā" Foreground="#A5D6C0" FontSize="14"/>
                            </Grid>
                        </Border>

                        <!-- Card 2: Incoming - White with Orange Accent -->
                        <Border Grid.Column="2" CornerRadius="24" Padding="24" Background="White">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="30" ShadowDepth="10" Opacity="0.08" Color="#000000"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                                    <Border Background="#ECFDF5" CornerRadius="14" Padding="12">
                                        <TextBlock Text="📥" FontSize="22"/>
                                    </Border>
                                    <TextBlock Text="Ienācis" Foreground="#64748B" FontSize="15" Margin="14,0,0,0" VerticalAlignment="Center" FontWeight="Medium"/>
                                </StackPanel>
                                <TextBlock Grid.Row="1" x:Name="HomeIncomingText" Text="0 t" FontSize="42" FontWeight="Bold" Foreground="#00875A" Margin="0,8,0,8"/>
                                <TextBlock Grid.Row="2" Text="šajā sezonā" Foreground="#94A3B8" FontSize="14"/>
                            </Grid>
                        </Border>

                        <!-- Card 3: Outgoing - White with Orange Accent -->
                        <Border Grid.Column="4" CornerRadius="24" Padding="24" Background="White">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="30" ShadowDepth="10" Opacity="0.08" Color="#000000"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                                    <Border Background="#FEF3C7" CornerRadius="14" Padding="12">
                                        <TextBlock Text="📤" FontSize="22"/>
                                    </Border>
                                    <TextBlock Text="Izejis" Foreground="#64748B" FontSize="15" Margin="14,0,0,0" VerticalAlignment="Center" FontWeight="Medium"/>
                                </StackPanel>
                                <TextBlock Grid.Row="1" x:Name="HomeOutgoingText" Text="0 t" FontSize="42" FontWeight="Bold" Foreground="#FFA033" Margin="0,8,0,8"/>
                                <TextBlock Grid.Row="2" Text="šajā sezonā" Foreground="#94A3B8" FontSize="14"/>
                            </Grid>
                        </Border>

                        <!-- Card 4: Target Progress - Donut Chart -->
                        <Border Grid.Column="6" CornerRadius="24" Padding="24" Background="White">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="30" ShadowDepth="10" Opacity="0.08" Color="#000000"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                                    <Border Background="#DBEAFE" CornerRadius="14" Padding="12">
                                        <TextBlock Text="🎯" FontSize="22"/>
                                    </Border>
                                    <TextBlock Text="Mērķis" Foreground="#64748B" FontSize="15" Margin="14,0,0,0" VerticalAlignment="Center" FontWeight="Medium"/>
                                </StackPanel>
                                <Grid Grid.Row="1" HorizontalAlignment="Center" Margin="0,10,0,10">
                                    <Ellipse Width="80" Height="80" Stroke="#E2E8F0" StrokeThickness="8"/>
                                    <Ellipse x:Name="HomeProgressArc" Width="80" Height="80" Stroke="#FFA033" StrokeThickness="8" StrokeDashArray="100" StrokeDashOffset="0">
                                        <Ellipse.RenderTransform>
                                            <RotateTransform Angle="-90" CenterX="40" CenterY="40"/>
                                        </Ellipse.RenderTransform>
                                    </Ellipse>
                                    <TextBlock x:Name="HomeProgressPercentText" Text="0%" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="20" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </Grid>
                                <TextBlock x:Name="HomeTargetText" Text="0 / 0 t" FontSize="14" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Details List -->
                    <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                                <Border Background="#EEF2FF" CornerRadius="8" Padding="10,6" Margin="0,0,10,0">
                                    <TextBlock Text="📋" FontSize="14"/>
                                </Border>
                                <TextBlock Text="Detalizēts saraksts" 
                                           FontSize="20" 
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <TreeView Grid.Row="1" 
                                      x:Name="InventoryTree"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Padding="0">
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem">
                                        <Setter Property="IsExpanded" Value="True"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                        <Setter Property="FontSize" Value="14"/>
                                        <Setter Property="Padding" Value="0"/>
                                    </Style>
                                </TreeView.ItemContainerStyle>
                            </TreeView>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Incoming Page -->
                <Grid x:Name="IncomingPage" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="Ienākošie kartupeļi" 
                                   FontSize="32" 
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Reģistrējiet jaunus kravas ienākumus noliktavā"
                                   FontSize="15"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,4,0,24"/>
                    </StackPanel>

                    <!-- Add Form -->
                    <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Datums" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                <DatePicker x:Name="IncomingDatePicker" SelectedDate="{x:Static sys:DateTime.Today}" 
                                            xmlns:sys="clr-namespace:System;assembly=mscorlib"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                <TextBlock Text="Šķirne" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                <ComboBox x:Name="IncomingVarietyCombo" Style="{StaticResource ModernComboBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                <TextBlock Text="Kalibrs" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                <ComboBox x:Name="IncomingCaliberCombo" Style="{StaticResource ModernComboBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3" Margin="0,0,8,0">
                                <TextBlock Text="Sv. (t)" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                <TextBox x:Name="IncomingContainerWeight" Style="{StaticResource ModernTextBox}" TextChanged="IncomingWeight_Changed"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4" Margin="0,0,8,0">
                                <TextBlock Text="Daudz" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                <TextBox x:Name="IncomingContainerCount" Style="{StaticResource ModernTextBox}" TextChanged="IncomingCount_Changed"/>
                            </StackPanel>

                            <StackPanel Grid.Column="5" Margin="0,0,8,0">
                                <TextBlock Text="Kopā (t)" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                <TextBox x:Name="IncomingTotalWeight" Style="{StaticResource ModernTextBox}" IsReadOnly="True" Background="#F3F4F6"/>
                            </StackPanel>

                            <Button Grid.Column="6" 
                                    Content="+ Pievienot" 
                                    Style="{StaticResource AccentButton}"
                                    Click="AddIncoming"
                                    VerticalAlignment="Bottom"/>
                        </Grid>
                    </Border>

                    <!-- List -->
                    <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                        <DataGrid x:Name="IncomingGrid"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  RowBackground="White"
                                  AlternatingRowBackground="#F8FAFC">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Datums" Binding="{Binding Date, StringFormat=d}" Width="SizeToCells"/>
                                <DataGridTextColumn Header="Šķirne" Binding="{Binding Variety.Name}" Width="SizeToCells"/>
                                <DataGridTextColumn Header="Kalibrs" Binding="{Binding Caliber.Name}" Width="SizeToCells"/>
                                <DataGridTextColumn Header="Sv. (t)" Binding="{Binding ContainerWeightTons, StringFormat=N3}" Width="SizeToCells">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Daudz" Binding="{Binding ContainerCount}" Width="SizeToCells"/>
                                <DataGridTextColumn Header="Kopā (t)" Binding="{Binding TotalWeightTons, StringFormat=N3}" Width="SizeToCells">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Width="60">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="✏️" 
                                                        Background="Transparent" 
                                                        BorderThickness="0" 
                                                        Cursor="Hand"
                                                        Click="EditIncoming"
                                                        Tag="{Binding Id}"
                                                        ToolTip="Rediģēt"
                                                        Margin="0,0,4,0"/>
                                                <Button Content="🗑️" 
                                                        Background="Transparent" 
                                                        BorderThickness="0" 
                                                        Cursor="Hand"
                                                        Click="DeleteIncoming"
                                                        Tag="{Binding Id}"
                                                        ToolTip="Dzēst"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>

                <!-- Outgoing Page -->
                <Grid x:Name="OutgoingPage" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="Izejošie kartupeļi" 
                                   FontSize="32" 
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Reģistrējiet pārdošanas un izsūtīšanas"
                                   FontSize="15"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,4,0,24"/>
                    </StackPanel>

                    <!-- Add Form -->
                    <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Datums" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                <DatePicker x:Name="OutgoingDatePicker" SelectedDate="{x:Static sys:DateTime.Today}"
                                            xmlns:sys="clr-namespace:System;assembly=mscorlib"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                <TextBlock Text="Šķirne" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                <ComboBox x:Name="OutgoingVarietyCombo" Style="{StaticResource ModernComboBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                <TextBlock Text="Kalibrs" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                <ComboBox x:Name="OutgoingCaliberCombo" Style="{StaticResource ModernComboBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3" Margin="0,0,8,0">
                                <TextBlock Text="Svars (t)" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                <TextBox x:Name="OutgoingWeight" Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4" Margin="0,0,8,0">
                                <TextBlock Text="Pircējs" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                <TextBox x:Name="OutgoingBuyer" Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>

                            <Button Grid.Column="5" 
                                    Content="+ Pievienot" 
                                    Style="{StaticResource ModernButton}"
                                    Click="AddOutgoing"
                                    VerticalAlignment="Bottom"/>
                        </Grid>
                    </Border>

                    <!-- List -->
                    <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,24,0,0">
                        <DataGrid x:Name="OutgoingGrid"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  RowBackground="White"
                                  AlternatingRowBackground="#F8FAFC">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Datums" Binding="{Binding Date, StringFormat=d}" Width="SizeToCells"/>
                                <DataGridTextColumn Header="Šķirne" Binding="{Binding Variety.Name}" Width="SizeToCells"/>
                                <DataGridTextColumn Header="Kalibrs" Binding="{Binding Caliber.Name}" Width="SizeToCells"/>
                                <DataGridTextColumn Header="Svars (t)" Binding="{Binding TotalWeightTons, StringFormat=N3}" Width="SizeToCells">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Pircējs" Binding="{Binding Buyer}" Width="SizeToCells"/>
                                <DataGridTemplateColumn Width="60">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="✏️" 
                                                        Background="Transparent" 
                                                        BorderThickness="0" 
                                                        Cursor="Hand"
                                                        Click="EditOutgoing"
                                                        Tag="{Binding Id}"
                                                        ToolTip="Rediģēt"
                                                        Margin="0,0,4,0"/>
                                                <Button Content="🗑️" 
                                                        Background="Transparent" 
                                                        BorderThickness="0" 
                                                        Cursor="Hand"
                                                        Click="DeleteOutgoing"
                                                        Tag="{Binding Id}"
                                                        ToolTip="Dzēst"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>

                <!-- Settings Page -->
                <Grid x:Name="SettingsPage" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="Iestatījumi" 
                                   FontSize="32" 
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Konfigurējiet sezonas, šķirnes un kalibrus"
                                   FontSize="15"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,4,0,24"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Season Management -->
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Text="Sezonas" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>

                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                                        <TextBox x:Name="NewSeasonName" Style="{StaticResource ModernTextBox}" Width="180" Margin="0,0,8,0"/>
                                        <Button Content="+ Pievienot" Style="{StaticResource ModernButton}" Click="AddSeason"/>
                                    </StackPanel>

                                    <Grid Grid.Row="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <ComboBox Grid.Column="0" x:Name="SeasonCombo" Style="{StaticResource ModernComboBox}" DisplayMemberPath="Name" SelectionChanged="SeasonSelectionChanged"/>
                                        <Button Grid.Column="1" Content="Aktīvā" Style="{StaticResource AccentButton}" Click="SetActiveSeason" Margin="8,0,0,0"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Usage/Target Section -->
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Text="Mērķis / Izmantošana" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>

                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Circular Progress -->
                                        <Grid Grid.Column="0" Width="80" Height="80" Margin="0,0,16,0">
                                            <Ellipse Stroke="#E5E7EB" StrokeThickness="6"/>
                                            <Ellipse x:Name="ProgressArc" Stroke="{StaticResource AccentBrush}" StrokeThickness="6" StrokeDashArray="100" StrokeDashOffset="0">
                                                <Ellipse.RenderTransform>
                                                    <RotateTransform Angle="-90" CenterX="40" CenterY="40"/>
                                                </Ellipse.RenderTransform>
                                            </Ellipse>
                                            <TextBlock x:Name="ProgressPercentText" Text="0%" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        </Grid>

                                        <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                            <TextBlock Text="Mērķa svars (t)" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                            <TextBox x:Name="SeasonTargetWeight" Style="{StaticResource ModernTextBox}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                            <TextBlock Text="Ienācis (t)" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                            <TextBox x:Name="SeasonIncomingTotal" Style="{StaticResource ModernTextBox}" IsReadOnly="True" Background="#F3F4F6"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="3" Margin="0,0,8,0">
                                            <TextBlock Text="Atlikums (t)" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                            <TextBox x:Name="SeasonRemaining" Style="{StaticResource ModernTextBox}" IsReadOnly="True" Background="#F3F4F6"/>
                                        </StackPanel>

                                        <Button Grid.Column="4" Content="Saglabāt" Style="{StaticResource ModernButton}" Click="SaveSeasonTarget" VerticalAlignment="Bottom"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Varieties and Calibers Side by Side -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Varieties -->
                                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Text="Šķirnes" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>

                                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                                            <TextBox x:Name="NewVarietyName" Style="{StaticResource ModernTextBox}" Width="120" Margin="0,0,8,0"/>
                                            <Button Content="+" Style="{StaticResource ModernButton}" Click="AddVariety"/>
                                        </StackPanel>

                                        <ListBox Grid.Row="2" x:Name="VarietiesList" BorderThickness="0" Background="Transparent" MaxHeight="200">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#F9FAFB" CornerRadius="6" Padding="10,8" Margin="0,0,0,4">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="13" Margin="0,0,8,0"/>
                                                            <Button Content="×" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="DeleteVariety" Tag="{Binding Id}" FontSize="14" Foreground="{StaticResource DangerBrush}"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>
                                </Border>

                                <!-- Calibers -->
                                <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Text="Kalibri" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>

                                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                                            <TextBox x:Name="NewCaliberName" Style="{StaticResource ModernTextBox}" Width="120" Margin="0,0,8,0"/>
                                            <Button Content="+" Style="{StaticResource ModernButton}" Click="AddCaliber"/>
                                        </StackPanel>

                                        <ListBox Grid.Row="2" x:Name="CalibersList" BorderThickness="0" Background="Transparent" MaxHeight="200">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#F9FAFB" CornerRadius="6" Padding="10,8" Margin="0,0,0,4">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="13" Margin="0,0,8,0"/>
                                                            <Button Content="×" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="DeleteCaliber" Tag="{Binding Id}" FontSize="14" Foreground="{StaticResource DangerBrush}"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
