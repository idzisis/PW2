<Window x:Class="PotatoWarehouse.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Noliktava - Kartupeļu pārvaldība"
        Width="1280" Height="800"
        MinWidth="1000" MinHeight="650"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundGradient}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Navigation Sidebar with Gradient -->
        <Border Grid.Column="0" Background="{StaticResource SidebarGradient}">
            <DockPanel>
                <!-- Logo/Title -->
                <StackPanel DockPanel.Dock="Top" Margin="20,30,20,10">
                    <StackPanel Orientation="Horizontal" Margin="10,0,0,8">
                        <TextBlock Text="🥔" FontSize="32" Margin="0,0,12,0"/>
                        <TextBlock Text="Noliktava"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Border Background="#4F46E5" CornerRadius="8" Padding="12,8" Margin="10,10,10,0">
                        <StackPanel>
                            <TextBlock Text="AKTĪVĀ SEZONA"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="#A5B4FC"
                                       Margin="0,0,0,4"/>
                            <TextBlock x:Name="SeasonLabel"
                                       Text="Nav izvēlēta"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="White"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Navigation -->
                <StackPanel Margin="10,20,10,20">
                    <Button Style="{StaticResource NavButton}" Click="NavigateHome" x:Name="HomeNav">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="#4F46E5" CornerRadius="8" Padding="8" Margin="0,0,14,0">
                                <TextBlock Text="🏠" FontSize="16"/>
                            </Border>
                            <TextBlock Text="Sākumlapa" VerticalAlignment="Center" FontSize="15"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}" Click="NavigateIncoming">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="#10B981" CornerRadius="8" Padding="8" Margin="0,0,14,0">
                                <TextBlock Text="📥" FontSize="16"/>
                            </Border>
                            <TextBlock Text="Ienākošie" VerticalAlignment="Center" FontSize="15"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}" Click="NavigateOutgoing">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="#F59E0B" CornerRadius="8" Padding="8" Margin="0,0,14,0">
                                <TextBlock Text="📤" FontSize="16"/>
                            </Border>
                            <TextBlock Text="Izejošie" VerticalAlignment="Center" FontSize="15"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}" Click="NavigateSettings">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="#6366F1" CornerRadius="8" Padding="8" Margin="0,0,14,0">
                                <TextBlock Text="⚙️" FontSize="16"/>
                            </Border>
                            <TextBlock Text="Iestatījumi" VerticalAlignment="Center" FontSize="15"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Footer -->
                <TextBlock DockPanel.Dock="Bottom"
                           Text="v1.0.0"
                           Foreground="#6366F1"
                           FontSize="12"
                           Margin="20,0,20,20"
                           HorizontalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Content Area -->
        <Border Grid.Column="1" Margin="30">
            <Grid x:Name="ContentArea">
                <!-- Home Page -->
                <Grid x:Name="HomePage">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" 
                               Text="Kartupeļu atlikums noliktavā" 
                               FontSize="32" 
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,8"/>
                    <TextBlock Grid.Row="1"
                               Text="Pārskats par pieejamo kartupeļu daudzumu"
                               FontSize="15"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,24"/>

                    <!-- Stats Cards Row -->
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Total Summary Card -->
                        <Border Grid.Row="0" Style="{StaticResource StatsCardStyle}" VerticalAlignment="Top" Margin="0,0,0,24">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#6366F1" Offset="0"/>
                                    <GradientStop Color="#4F46E5" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="KOPĒJAIS ATLIKUMS" 
                                               FontSize="13" 
                                               FontWeight="SemiBold"
                                               Foreground="#C7D2FE"
                                               Margin="0,0,0,8"/>
                                    <TextBlock x:Name="TotalWeightText" 
                                               Text="0 kg" 
                                               FontSize="48" 
                                               FontWeight="Bold"
                                               Foreground="White"/>
                                    <TextBlock Text="kartupeļu noliktavā"
                                               FontSize="14"
                                               Foreground="#C7D2FE"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                                <Border Grid.Column="1" Background="#4F46E5" CornerRadius="50" Width="100" Height="100" Opacity="0.3">
                                    <TextBlock Text="🥔" FontSize="48" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Details List -->
                        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                                    <Border Background="#EEF2FF" CornerRadius="8" Padding="10,6" Margin="0,0,10,0">
                                        <TextBlock Text="📋" FontSize="14"/>
                                    </Border>
                                    <TextBlock Text="Detalizēts saraksts" 
                                               FontSize="20" 
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               VerticalAlignment="Center"/>

                                </StackPanel>

                                <DataGrid Grid.Row="1" 
                                          x:Name="InventoryGrid"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          GridLinesVisibility="Horizontal"
                                          HeadersVisibility="Column"
                                          BorderThickness="0"
                                          Background="Transparent"
                                          RowBackground="White"
                                          AlternatingRowBackground="#F8FAFC">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Šķirne" Binding="{Binding VarietyName}" Width="*"/>
                                        <DataGridTextColumn Header="Kalibrs" Binding="{Binding CaliberName}" Width="*"/>
                                        <DataGridTextColumn Header="Svars (kg)" Binding="{Binding Weight, StringFormat=N2}" Width="150">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="Foreground" Value="#6366F1"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Incoming Page -->
                <Grid x:Name="IncomingPage" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="Ienākošie kartupeļi" 
                                   FontSize="32" 
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Reģistrējiet jaunus kravas ienākumus noliktavā"
                                   FontSize="15"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,4,0,24"/>
                    </StackPanel>

                    <!-- Add Form -->
                    <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="Datums" Margin="0,0,0,8" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="Medium" FontSize="13"/>
                                <DatePicker x:Name="IncomingDatePicker" SelectedDate="{x:Static sys:DateTime.Today}" 
                                            xmlns:sys="clr-namespace:System;assembly=mscorlib"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                <TextBlock Text="Šķirne" Margin="0,0,0,8" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="Medium" FontSize="13"/>
                                <ComboBox x:Name="IncomingVarietyCombo" Style="{StaticResource ModernComboBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="0,0,12,0">
                                <TextBlock Text="Kalibrs" Margin="0,0,0,8" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="Medium" FontSize="13"/>
                                <ComboBox x:Name="IncomingCaliberCombo" Style="{StaticResource ModernComboBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3" Margin="0,0,12,0">
                                <TextBlock Text="Konteinera svars (kg)" Margin="0,0,0,8" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="Medium" FontSize="13"/>
                                <TextBox x:Name="IncomingContainerWeight" Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4" Margin="0,0,12,0">
                                <TextBlock Text="Konteineru skaits" Margin="0,0,0,8" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="Medium" FontSize="13"/>
                                <TextBox x:Name="IncomingContainerCount" Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>

                            <Button Grid.Column="5" 
                                    Content="+ Pievienot" 
                                    Style="{StaticResource AccentButton}"
                                    Click="AddIncoming"
                                    VerticalAlignment="Bottom"/>
                        </Grid>
                    </Border>

                    <!-- List -->
                    <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                        <DataGrid x:Name="IncomingGrid"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  RowBackground="White"
                                  AlternatingRowBackground="#F8FAFC">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Datums" Binding="{Binding Date, StringFormat=d}" Width="100"/>
                                <DataGridTextColumn Header="Šķirne" Binding="{Binding Variety.Name}" Width="*"/>
                                <DataGridTextColumn Header="Kalibrs" Binding="{Binding Caliber.Name}" Width="*"/>
                                <DataGridTextColumn Header="Kont. svars (kg)" Binding="{Binding ContainerWeight, StringFormat=N2}" Width="120"/>
                                <DataGridTextColumn Header="Kont. skaits" Binding="{Binding ContainerCount}" Width="100"/>
                                <DataGridTextColumn Header="Kopā (kg)" Binding="{Binding TotalWeight, StringFormat=N2}" Width="120">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Foreground" Value="#10B981"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Width="70">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="🗑️" 
                                                    Background="Transparent" 
                                                    BorderThickness="0" 
                                                    Cursor="Hand"
                                                    Click="DeleteIncoming"
                                                    Tag="{Binding Id}"
                                                    ToolTip="Dzēst"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>

                <!-- Outgoing Page -->
                <Grid x:Name="OutgoingPage" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="Izejošie kartupeļi" 
                                   FontSize="32" 
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Reģistrējiet pārdošanas un izsūtīšanas"
                                   FontSize="15"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,4,0,24"/>
                    </StackPanel>

                    <!-- Add Form -->
                    <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="Datums" Margin="0,0,0,8" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="Medium" FontSize="13"/>
                                <DatePicker x:Name="OutgoingDatePicker" SelectedDate="{x:Static sys:DateTime.Today}"
                                            xmlns:sys="clr-namespace:System;assembly=mscorlib"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                <TextBlock Text="Šķirne" Margin="0,0,0,8" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="Medium" FontSize="13"/>
                                <ComboBox x:Name="OutgoingVarietyCombo" Style="{StaticResource ModernComboBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="0,0,12,0">
                                <TextBlock Text="Kalibrs" Margin="0,0,0,8" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="Medium" FontSize="13"/>
                                <ComboBox x:Name="OutgoingCaliberCombo" Style="{StaticResource ModernComboBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3" Margin="0,0,12,0">
                                <TextBlock Text="Konteinera svars (kg)" Margin="0,0,0,8" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="Medium" FontSize="13"/>
                                <TextBox x:Name="OutgoingContainerWeight" Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4" Margin="0,0,12,0">
                                <TextBlock Text="Konteineru skaits" Margin="0,0,0,8" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="Medium" FontSize="13"/>
                                <TextBox x:Name="OutgoingContainerCount" Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="5" Margin="0,0,12,0">
                                <TextBlock Text="Pircējs" Margin="0,0,0,8" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="Medium" FontSize="13"/>
                                <TextBox x:Name="OutgoingBuyer" Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>

                            <Button Grid.Column="6" 
                                    Content="+ Pievienot" 
                                    Style="{StaticResource ModernButton}"
                                    Click="AddOutgoing"
                                    VerticalAlignment="Bottom"/>
                        </Grid>
                    </Border>

                    <!-- List -->
                    <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                        <DataGrid x:Name="OutgoingGrid"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  RowBackground="White"
                                  AlternatingRowBackground="#F8FAFC">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Datums" Binding="{Binding Date, StringFormat=d}" Width="100"/>
                                <DataGridTextColumn Header="Šķirne" Binding="{Binding Variety.Name}" Width="*"/>
                                <DataGridTextColumn Header="Kalibrs" Binding="{Binding Caliber.Name}" Width="*"/>
                                <DataGridTextColumn Header="Kont. svars (kg)" Binding="{Binding ContainerWeight, StringFormat=N2}" Width="100"/>
                                <DataGridTextColumn Header="Kont. skaits" Binding="{Binding ContainerCount}" Width="80"/>
                                <DataGridTextColumn Header="Kopā (kg)" Binding="{Binding TotalWeight, StringFormat=N2}" Width="100">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Foreground" Value="#F59E0B"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Pircējs" Binding="{Binding Buyer}" Width="*"/>
                                <DataGridTemplateColumn Width="70">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="🗑️" 
                                                    Background="Transparent" 
                                                    BorderThickness="0" 
                                                    Cursor="Hand"
                                                    Click="DeleteOutgoing"
                                                    Tag="{Binding Id}"
                                                    ToolTip="Dzēst"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>

                <!-- Settings Page -->
                <Grid x:Name="SettingsPage" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="Iestatījumi" 
                                   FontSize="32" 
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Konfigurējiet sezonas, šķirnes un kalibrus"
                                   FontSize="15"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,4,0,24"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Season Management -->
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,24">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                                        <Border Background="#EEF2FF" CornerRadius="10" Padding="12" Margin="0,0,16,0">
                                            <TextBlock Text="📅" FontSize="20"/>
                                        </Border>
                                        <StackPanel>
                                            <TextBlock Text="Sezonas pārvaldība" 
                                                       FontSize="20" 
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text="Pievienojiet un pārvaldiet sezonas"
                                                       FontSize="13"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
                                        <TextBox x:Name="NewSeasonName" 
                                                 Style="{StaticResource ModernTextBox}" 
                                                 Width="250"
                                                 Margin="0,0,12,0"/>
                                        <Button Content="+ Pievienot sezonu" 
                                                Style="{StaticResource ModernButton}"
                                                Click="AddSeason"/>
                                    </StackPanel>

                                    <Grid Grid.Row="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <ComboBox Grid.Column="0" 
                                                  x:Name="SeasonCombo" 
                                                  Style="{StaticResource ModernComboBox}"
                                                  DisplayMemberPath="Name"
                                                  SelectionChanged="SeasonSelectionChanged"/>
                                        <Button Grid.Column="1" 
                                                Content="Iestatīt kā aktīvo" 
                                                Style="{StaticResource AccentButton}"
                                                Click="SetActiveSeason"
                                                Margin="12,0,0,0"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Varieties Management -->
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,24">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                                        <Border Background="#DCFCE7" CornerRadius="10" Padding="12" Margin="0,0,16,0">
                                            <TextBlock Text="🌿" FontSize="20"/>
                                        </Border>
                                        <StackPanel>
                                            <TextBlock Text="Šķirnes" 
                                                       FontSize="20" 
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text="Pievienojiet jaunas šķirnes"
                                                       FontSize="13"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
                                        <TextBox x:Name="NewVarietyName" 
                                                 Style="{StaticResource ModernTextBox}" 
                                                 Width="250"
                                                 Margin="0,0,12,0"/>
                                        <Button Content="+ Pievienot šķirni" 
                                                Style="{StaticResource ModernButton}"
                                                Click="AddVariety"/>
                                    </StackPanel>

                                    <ListBox Grid.Row="2" 
                                             x:Name="VarietiesList"
                                             BorderThickness="0"
                                             Background="Transparent">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#F8FAFC" 
                                                        CornerRadius="10" 
                                                        Padding="16,12" 
                                                        Margin="0,0,0,8">
                                                    <Grid>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Border Background="#EEF2FF" CornerRadius="6" Padding="8" Margin="0,0,12,0">
                                                                <TextBlock Text="🥔" FontSize="14"/>
                                                            </Border>
                                                            <TextBlock Text="{Binding Name}" 
                                                                       VerticalAlignment="Center"
                                                                       FontSize="15"
                                                                       FontWeight="Medium"/>
                                                        </StackPanel>
                                                        <Button Content="🗑️" 
                                                                HorizontalAlignment="Right"
                                                                Background="Transparent" 
                                                                BorderThickness="0" 
                                                                Cursor="Hand"
                                                                Click="DeleteVariety"
                                                                Tag="{Binding Id}"
                                                                ToolTip="Dzēst"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Border>

                            <!-- Calibers Management -->
                            <Border Style="{StaticResource CardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                                        <Border Background="#FEF3C7" CornerRadius="10" Padding="12" Margin="0,0,16,0">
                                            <TextBlock Text="📏" FontSize="20"/>
                                        </Border>
                                        <StackPanel>
                                            <TextBlock Text="Kalibri" 
                                                       FontSize="20" 
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text="Pievienojiet jaunus kalibrus"
                                                       FontSize="13"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
                                        <TextBox x:Name="NewCaliberName" 
                                                 Style="{StaticResource ModernTextBox}" 
                                                 Width="250"
                                                 Margin="0,0,12,0"/>
                                        <Button Content="+ Pievienot kalibru" 
                                                Style="{StaticResource ModernButton}"
                                                Click="AddCaliber"/>
                                    </StackPanel>

                                    <ListBox Grid.Row="2" 
                                             x:Name="CalibersList"
                                             BorderThickness="0"
                                             Background="Transparent">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#F8FAFC" 
                                                        CornerRadius="10" 
                                                        Padding="16,12" 
                                                        Margin="0,0,0,8">
                                                    <Grid>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Border Background="#FEF3C7" CornerRadius="6" Padding="8" Margin="0,0,12,0">
                                                                <TextBlock Text="📐" FontSize="14"/>
                                                            </Border>
                                                            <TextBlock Text="{Binding Name}" 
                                                                       VerticalAlignment="Center"
                                                                       FontSize="15"
                                                                       FontWeight="Medium"/>
                                                        </StackPanel>
                                                        <Button Content="🗑️" 
                                                                HorizontalAlignment="Right"
                                                                Background="Transparent" 
                                                                BorderThickness="0" 
                                                                Cursor="Hand"
                                                                Click="DeleteCaliber"
                                                                Tag="{Binding Id}"
                                                                ToolTip="Dzēst"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
